{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "outDir": "lib",
    "rootDir": "../..",
    "declarationDir": "lib",
    "composite": false,
    "incremental": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "allowJs": true,
    "resolveJsonModule": true,
    "rootDirs": [
      "../../src",
      "../../packages",
      "../../plugins"
    ],
    "paths": {
      "src/*": [
        "src/*"
      ],
      "packages/*": [
        "packages/*"
      ],
      "plugins/*": [
        "plugins/*"
      ]
    }
  },
  "include": [
    "src*",
    "types*",
    "../../src/**/*",
    "src/**/*"
  ],
  "exclude": [
    "src*.test.*",
    "src*.stories.*",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/test/**",
    "**/spec/**"
  ]
}
